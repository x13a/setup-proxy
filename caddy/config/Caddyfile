{
    # debug
    admin off
}

(proxy_handler) {
    encode
    root * /www
    route {
        reverse_proxy {$PANEL_PATH}/* {$PANEL}:{$PANEL_PORT}
        reverse_proxy {$SUBSCRIPTION_PATH}/* {$PANEL}:{$SUBSCRIPTION_PORT}
        handle {
            import "./basic_auth.caddy"
            file_server
        }
    }
}

www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri}
}

{$DOMAIN} {
    import proxy_handler
}

{$IP_SUBDOMAIN}.{$DOMAIN} {
    encode
    templates
    respond "{{.RemoteIP}}"
}

# healthcheck
http://localhost:8000 {
    respond "OK"
}
